# Example Environment Variables for Docker Compose
# Copy this file to .env and adjust values as needed

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=transactionprimarydb

# Database Connection (for Spring Boot)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/transactionprimarydb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password

# Flyway Configuration
SPRING_FLYWAY_URL=jdbc:postgresql://postgres:5432/transactionprimarydb
SPRING_FLYWAY_USER=postgres
SPRING_FLYWAY_PASSWORD=password

# Redis Configuration (uncomment if using Redis)
# SPRING_DATA_REDIS_HOST=redis
# SPRING_DATA_REDIS_PORT=6379
# SPRING_DATA_REDIS_PASSWORD=redispassword

# Application Port
APP_PORT=8080

# Database Port (exposed to host)
DB_PORT=5436
